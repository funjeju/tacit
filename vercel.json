{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "functions": {
    "app/api/**": {
      "maxDuration": 60
    },
    "app/api/prompt/stream/route.ts": {
      "maxDuration": 120
    },
    "app/api/interview/question/route.ts": {
      "maxDuration": 120
    },
    "app/api/interview/complete/route.ts": {
      "maxDuration": 120
    }
  },
  "env": {
    "NEXT_PUBLIC_FIREBASE_API_KEY": "@tacit-firebase-api-key",
    "NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN": "@tacit-firebase-auth-domain",
    "NEXT_PUBLIC_FIREBASE_PROJECT_ID": "@tacit-firebase-project-id",
    "NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET": "@tacit-firebase-storage-bucket",
    "NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "@tacit-firebase-messaging-sender-id",
    "NEXT_PUBLIC_FIREBASE_APP_ID": "@tacit-firebase-app-id",
    "FIREBASE_ADMIN_PROJECT_ID": "@tacit-admin-project-id",
    "FIREBASE_ADMIN_CLIENT_EMAIL": "@tacit-admin-client-email",
    "FIREBASE_ADMIN_PRIVATE_KEY": "@tacit-admin-private-key",
    "ANTHROPIC_API_KEY": "@tacit-anthropic-api-key",
    "NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID": "@tacit-firebase-measurement-id",
    "ADMIN_UIDS": "@tacit-admin-uids",
    "NEXT_PUBLIC_SENTRY_DSN": "@tacit-sentry-dsn",
    "SENTRY_ORG": "@tacit-sentry-org",
    "SENTRY_PROJECT": "@tacit-sentry-project",
    "SENTRY_AUTH_TOKEN": "@tacit-sentry-auth-token",
    "NEXT_PUBLIC_TOSS_CLIENT_KEY": "@tacit-toss-client-key",
    "TOSS_SECRET_KEY": "@tacit-toss-secret-key"
  }
}
