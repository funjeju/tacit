rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─────────────────────────────────────────
    // users/{userId}
    // ─────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);

      match /usage/{month} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─────────────────────────────────────────
    // prompts/{promptId}
    // ─────────────────────────────────────────
    match /prompts/{promptId} {
      allow read: if resource.data.isPublished == true
                  || (isSignedIn() && resource.data.ownerId == request.auth.uid)
                  || isAdmin();

      allow create: if isSignedIn()
                    && request.resource.data.ownerId == request.auth.uid;

      allow update: if isOwner(resource.data.ownerId) || isAdmin();

      allow delete: if isOwner(resource.data.ownerId) || isAdmin();

      // reports 서브컬렉션 — 로그인 유저가 생성, 본인 및 어드민만 읽기
      match /reports/{reportId} {
        allow read: if isOwner(reportId) || isAdmin();
        allow create: if isSignedIn()
                      && reportId == request.auth.uid
                      && request.resource.data.keys().hasAll(['reason', 'status', 'createdAt'])
                      && request.resource.data.status == 'pending';
        allow update, delete: if isAdmin();
      }
    }

    // ─────────────────────────────────────────
    // domainTemplates/{templateId}  (공개 읽기, 어드민 쓰기)
    // ─────────────────────────────────────────
    match /domainTemplates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────
    // domainProfiles/{profileId}  (본인 소유)
    // ─────────────────────────────────────────
    match /domainProfiles/{profileId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ─────────────────────────────────────────
    // interviews/{interviewId}  (본인 소유)
    // ─────────────────────────────────────────
    match /interviews/{interviewId} {
      allow read, update, delete: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;
    }

    // 그 외 모든 경로 — 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
